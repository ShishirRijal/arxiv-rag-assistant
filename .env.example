# Copy this file to .env and fill values for local development

OLLAMA_MODEL=llama3.2:1b

# PostgreSQL
POSTGRES_DB=ragdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Airflow. Generate AIRFLOW_FERNET_KEY with:
#   python3 -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_SECRET_KEY=
AIRFLOW_FERNET_KEY=

# Jina embeddings. Empty means hybrid search falls back to BM25.
JINA_API_KEY=

# Redis response cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL_HOURS=24
REDIS_ENABLED=true

# Langfuse observability. Leave empty to disable tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
LANGFUSE_ENABLED=true

# Agentic RAG workflow controls
AGENTIC_GUARDRAIL_THRESHOLD=60
AGENTIC_MAX_RETRIEVAL_ATTEMPTS=2
AGENTIC_TOP_K=5
AGENTIC_TEMPERATURE=0.0

# Telegram bot interface. Empty token means the bot service cannot start.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_API_BASE_URL=http://localhost:8000
TELEGRAM_REQUEST_TIMEOUT=60
TELEGRAM_USE_AGENTIC_RAG=true
