# Copy this file to .env and fill values for local development

OLLAMA_MODEL=llama3.2:1b

# Jina embeddings. Empty means hybrid search falls back to BM25.
JINA_API_KEY=

# Redis response cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL_HOURS=24
REDIS_ENABLED=true

# Langfuse observability. Leave empty to disable tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
LANGFUSE_ENABLED=true
